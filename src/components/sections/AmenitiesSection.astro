---
import type { AmenitiesSection as AmenitiesSectionType } from "../../sanity/types";

const { section } = Astro.props as { section: AmenitiesSectionType };
---

<section id={section.anchorId} class="py-24">
  <div class="container-shell grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="space-y-4">
      {
        section.sectionLabel && (
          <p class="section-eyebrow">{section.sectionLabel}</p>
        )
      }
      <h2 class="section-title text-[var(--forest)]">{section.title}</h2>
      {
        section.description && (
          <p class="section-copy text-lg">{section.description}</p>
        )
      }
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        section.amenities?.map((item) => (
          <article class="rounded-[1.6rem] border border-[var(--line)] bg-white/70 p-6 shadow-[var(--shadow)]">
            <h3 class="text-3xl text-[var(--forest)]">{item.title}</h3>
            {item.description && (
              <p class="mt-3 text-sm leading-7 text-[var(--muted)]">
                {item.description}
              </p>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
