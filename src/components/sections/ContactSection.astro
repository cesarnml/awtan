---
import type { ContactSection as ContactSectionType } from "../../sanity/types";

const { section } = Astro.props as { section: ContactSectionType };
---

<section id={section.anchorId} class="py-24">
  <div class="container-shell grid gap-10 lg:grid-cols-[1fr_0.9fr]">
    <div class="space-y-5">
      {
        section.sectionLabel && (
          <p class="section-eyebrow">{section.sectionLabel}</p>
        )
      }
      <h2 class="section-title text-[var(--forest)]">{section.title}</h2>
      {
        section.description && (
          <p class="section-copy max-w-2xl text-lg">{section.description}</p>
        )
      }
      {
        section.primaryCta && (
          <a
            href={section.primaryCta.href}
            class="inline-flex rounded-full border border-[var(--accent)] bg-[var(--accent)] px-6 py-3 text-sm font-semibold text-white hover:-translate-y-0.5 hover:bg-[var(--accent-strong)]"
          >
            {section.primaryCta.label}
          </a>
        )
      }
    </div>

    <div
      class="rounded-[2rem] border border-[var(--line)] bg-white/70 p-8 shadow-[var(--shadow)]"
    >
      <div class="grid gap-6 text-sm leading-7 text-[var(--muted)]">
        {
          section.addressLines?.length ? (
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--accent-strong)]">
                Address
              </div>
              <div class="mt-2 text-base text-[var(--ink)]">
                {section.addressLines.join(", ")}
              </div>
            </div>
          ) : null
        }
        {
          section.hours && (
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--accent-strong)]">
                Hours
              </div>
              <div class="mt-2 text-base text-[var(--ink)]">
                {section.hours}
              </div>
            </div>
          )
        }
        {
          section.phone && (
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--accent-strong)]">
                Phone
              </div>
              <a
                class="mt-2 block text-base text-[var(--ink)] hover:text-[var(--accent-strong)]"
                href={`tel:${section.phone}`}
              >
                {section.phone}
              </a>
            </div>
          )
        }
        {
          section.email && (
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--accent-strong)]">
                Email
              </div>
              <a
                class="mt-2 block text-base text-[var(--ink)] hover:text-[var(--accent-strong)]"
                href={`mailto:${section.email}`}
              >
                {section.email}
              </a>
            </div>
          )
        }
        {
          section.mapHref && section.mapLabel && (
            <a
              class="inline-flex text-sm font-semibold text-[var(--accent-strong)] hover:text-[var(--accent)]"
              href={section.mapHref}
              target="_blank"
              rel="noreferrer"
            >
              {section.mapLabel}
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>
